    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Current",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "justMyCode": false
